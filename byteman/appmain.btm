# 1. java -javaagent:${BYTEMAN_HOME}/lib/byteman.jar=script:appmain.btm AppMain foo bar baz
# 2. bmjava.sh -l appmain.btm AppMain foo bar baz

RULE trace main entry
CLASS AppMain
METHOD main
AT ENTRY
IF true
DO traceln("entering main")
ENDRULE

####

RULE trace main exit
CLASS AppMain
METHOD main
AT EXIT
IF true
DO traceln("exiting main")
ENDRULE